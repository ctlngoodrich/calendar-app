generator client {
  provider = "prisma-client-js"
  // output removed - use default
}

datasource db {
  provider = "sqlite"
}

model Booking {
  id        String   @id @default(cuid())
  name      String
  email     String
  reason    String
  startTime DateTime
  endTime   DateTime
  outlookId String?
  createdAt DateTime @default(now())
}
